{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>Recent content on {{ .Site.Title }}</description>
    <generator>Hugo -- gohugo.io</generator>
    <language>{{ .Site.LanguageCode | default "zh-tw" }}</language>
    
    <!-- 1. 放置標準的純文字版權宣告 -->
    <copyright>Copyright 2026 卡美桑的家. All rights reserved.</copyright>
    
    <!-- 2. 放置管理員或作者信箱 -->
    <managingEditor>taitungchishang@gmail.com (卡美桑)</managingEditor>
    
    <image>
      <url>{{ "images/logo.png" | absURL }}</url>
      <title>{{ .Site.Title }}</title>
      <link>{{ .Site.BaseURL }}</link>
    </image>

    {{- $pages := .Site.RegularPages -}}
    {{- range first 20 $pages -}}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      
      <!-- 修正重點：利用 html 轉義處理內文，並以標準不帶安全漏洞的方式輸出，防止內容破壞 XML 結構 -->
      <description>
        {{- "<![CDATA[" | safeHTML -}}
        {{- .Content | html -}}
        {{- "]]>" | safeHTML -}}
      </description>
    </item>
    {{- end -}}
  </channel>
</rss>